{
    "name": "saas",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "prisma generate && next build",
        "start": "next start",
        "lint": "eslint",
        "type-check": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "e2e": "dotenv -e .env -- playwright test",
        "e2e:ui": "dotenv -e .env -- playwright test --ui",
        "db:migrate": "dotenv -e .env -- prisma migrate dev",
        "db:migrate:deploy": "dotenv -e .env -- prisma migrate deploy",
        "db:migrate:deploy:prod": "dotenv -e .env.prod -- prisma migrate deploy",
        "db:migrate:resolve:prod": "dotenv -e .env.prod -- prisma migrate resolve",
        "db:migrate:status": "dotenv -e .env -- prisma migrate status",
        "db:migrate:status:prod": "dotenv -e .env.prod -- prisma migrate status",
        "db:generate": "dotenv -e .env -- prisma generate",
        "db:studio": "dotenv -e .env -- prisma studio",
        "db:seed": "dotenv -e .env -- tsx prisma/seed.ts",
        "db:seed:prod": "dotenv -e .env.prod -- tsx prisma/seed.ts",
        "db:seed-demo": "dotenv -e .env -- tsx prisma/seed-demo.ts",
        "db:seed-demo:prod": "dotenv -e .env.prod -- tsx prisma/seed-demo.ts",
        "db:wipe-dev": "dotenv -e .env -- tsx prisma/wipe-dev.ts",
        "db:tenant-export": "dotenv -e .env -- tsx scripts/tenant-export.ts",
        "db:tenant-export:prod": "dotenv -e .env.prod -- tsx scripts/tenant-export.ts",
        "db:tenant-restore": "dotenv -e .env -- tsx scripts/tenant-restore.ts",
        "db:tenant-restore:prod": "dotenv -e .env.prod -- tsx scripts/tenant-restore.ts",
        "db:backup": "dotenv -e .env -- tsx scripts/db-backup.ts",
        "db:backup:prod": "dotenv -e .env.prod -- tsx scripts/db-backup.ts"
    },
    "dependencies": {
        "@base-ui/react": "^1.4.0",
        "@fullcalendar/core": "^6.1.20",
        "@fullcalendar/daygrid": "^6.1.20",
        "@fullcalendar/interaction": "^6.1.20",
        "@fullcalendar/list": "^6.1.20",
        "@fullcalendar/luxon3": "^6.1.20",
        "@fullcalendar/react": "^6.1.20",
        "@fullcalendar/timegrid": "^6.1.20",
        "@hookform/resolvers": "^5.2.2",
        "@prisma/adapter-pg": "^7.7.0",
        "@prisma/client": "^7.7.0",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-select": "^2.2.6",
        "@sentry/nextjs": "^10.51.0",
        "@supabase/ssr": "^0.10.2",
        "@supabase/supabase-js": "^2.103.3",
        "@tanstack/react-query": "^5.99.0",
        "@trpc/client": "^11.13.0",
        "@trpc/next": "^11.13.0",
        "@trpc/react-query": "^11.13.0",
        "@trpc/server": "^11.13.0",
        "@upstash/ratelimit": "^2.0.8",
        "@upstash/redis": "^1.38.0",
        "@vercel/analytics": "^2.0.1",
        "@vercel/speed-insights": "^2.0.0",
        "@zxing/browser": "^0.2.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "gray-matter": "^4.0.3",
        "jspdf": "^4.2.1",
        "jspdf-autotable": "^5.0.7",
        "lucide-react": "^1.8.0",
        "luxon": "^3.7.2",
        "next": "16.2.4",
        "next-intl": "^4.9.1",
        "next-themes": "^0.4.6",
        "pg": "^8.20.0",
        "posthog-js": "^1.372.5",
        "prisma": "^7.7.0",
        "qrcode": "^1.5.4",
        "react": "19.2.4",
        "react-day-picker": "^9.14.0",
        "react-dom": "19.2.4",
        "react-hook-form": "^7.72.1",
        "react-markdown": "^10.1.0",
        "recharts": "^3.8.1",
        "remark-gfm": "^4.0.1",
        "shadcn": "^4.3.0",
        "sonner": "^2.0.7",
        "superjson": "^2.2.6",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0",
        "web-push": "^3.6.7",
        "xlsx": "^0.18.5",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@playwright/test": "^1.60.0",
        "@tailwindcss/postcss": "^4",
        "@types/luxon": "^3.7.1",
        "@types/node": "^20",
        "@types/pg": "^8.20.0",
        "@types/qrcode": "^1.5.6",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@types/web-push": "^3.6.4",
        "dotenv": "^17.4.2",
        "dotenv-cli": "^11.0.0",
        "eslint": "^9",
        "eslint-config-next": "16.2.4",
        "tailwindcss": "^4",
        "tsx": "^4.21.0",
        "typescript": "^5",
        "vitest": "^4.1.7"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "prisma",
            "@prisma/engines",
            "@swc/core",
            "@parcel/watcher",
            "esbuild"
        ]
    }
}
