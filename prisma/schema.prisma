generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────
// Enums
// ──────────────────────────────────────────

enum UserRole {
  ADMIN
  SECRETARY
  INSTRUCTOR
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ClassType {
  THEORY
  PRACTICAL
}

enum ClassStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EnrollmentStatus {
  ENROLLED
  CANCELLED
  ATTENDED
  NO_SHOW
}

enum TenantStatus {
  ACTIVE
  INACTIVE
}

enum LicenseCategory {
  AM
  A1
  A2
  A
  B1
  B
  BE
  C1
  C1E
  C
  D1
  D1E
  D
  DE
}

enum CourseStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum ExamType {
  THEORY
  PRACTICAL
}

enum ExamResult {
  SCHEDULED
  PASSED
  FAILED
  NO_SHOW
  CANCELLED
}

// ──────────────────────────────────────────
// Models
// ──────────────────────────────────────────

model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  schools School[]
  users   User[]

  @@map("tenants")
}

model School {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  subdomain String   @unique
  name      String
  address   String?
  phone     String?
  // Minimum notice (in hours) a student must give to cancel an enrollment.
  // 0 = always allowed; staff (admin/secretary/instructor) bypass this.
  cancellationNoticeHours Int @default(24) @map("cancellation_notice_hours")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  users          User[]
  sessions       ClassSession[]
  enrollments    Enrollment[]
  notifications  Notification[]
  studentCourses StudentCourse[]

  @@index([tenantId])
  @@map("schools")
}

model User {
  id        String     @id @db.Uuid // matches Supabase auth.users.id
  tenantId  String     @map("tenant_id") @db.Uuid
  schoolId  String     @map("school_id") @db.Uuid
  email     String
  name      String
  phone     String?
  role      UserRole
  status    UserStatus @default(ACTIVE)
  // Categories an instructor is qualified to teach. Empty for non-instructors.
  qualifiedCategories LicenseCategory[] @default([]) @map("qualified_categories")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  school        School         @relation(fields: [schoolId], references: [id])
  enrollments       Enrollment[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]

  // Classes where this user is the instructor
  instructedSessions ClassSession[] @relation("InstructorSessions")

  // Audit trail: classes created/modified by this user
  createdSessions ClassSession[] @relation("CreatedBySessions")
  updatedSessions ClassSession[] @relation("UpdatedBySessions")

  // Driving courses (only meaningful for STUDENT role)
  studentCourses StudentCourse[]

  // Practical exams this instructor is accompanying
  accompaniedExams Exam[] @relation("InstructorExams")

  // Audit trail for exams
  createdExams Exam[] @relation("CreatedByExams")
  updatedExams Exam[] @relation("UpdatedByExams")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([schoolId])
  @@map("users")
}

model ClassSession {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @map("tenant_id") @db.Uuid
  schoolId     String      @map("school_id") @db.Uuid
  classType    ClassType   @map("class_type")
  // License category this class is taught for. Nullable to keep legacy rows valid;
  // required at the validation layer for newly created classes.
  category     LicenseCategory?
  instructorId String      @map("instructor_id") @db.Uuid
  title        String
  startsAt     DateTime    @map("starts_at")
  endsAt       DateTime    @map("ends_at")
  capacity     Int
  status       ClassStatus @default(SCHEDULED)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  createdById  String      @map("created_by") @db.Uuid
  updatedById  String      @map("updated_by") @db.Uuid

  school      School       @relation(fields: [schoolId], references: [id])
  instructor  User         @relation("InstructorSessions", fields: [instructorId], references: [id])
  createdBy   User         @relation("CreatedBySessions", fields: [createdById], references: [id])
  updatedBy   User         @relation("UpdatedBySessions", fields: [updatedById], references: [id])
  enrollments Enrollment[]

  @@index([tenantId])
  @@index([schoolId])
  @@index([instructorId])
  @@index([startsAt])
  @@map("class_sessions")
}

model Enrollment {
  id         String           @id @default(uuid()) @db.Uuid
  tenantId   String           @map("tenant_id") @db.Uuid
  schoolId   String           @map("school_id") @db.Uuid
  sessionId  String           @map("session_id") @db.Uuid
  studentId  String           @map("student_id") @db.Uuid
  status     EnrollmentStatus @default(ENROLLED)
  notes      String?          // Instructor notes about the student's performance
  enrolledAt DateTime         @default(now()) @map("enrolled_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  school  School       @relation(fields: [schoolId], references: [id])
  session ClassSession @relation(fields: [sessionId], references: [id])
  student User         @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
  @@index([tenantId])
  @@index([schoolId])
  @@index([sessionId])
  @@index([studentId])
  @@map("enrollments")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  schoolId  String   @map("school_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   // e.g. "enrollment.created", "class.cancelled", "attendance.marked"
  title     String
  message   String
  data      Json?    // optional payload (classId, enrollmentId, etc.)
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  school School @relation(fields: [schoolId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([schoolId])
  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

model StudentCourse {
  id          String          @id @default(uuid()) @db.Uuid
  tenantId    String          @map("tenant_id") @db.Uuid
  schoolId    String          @map("school_id") @db.Uuid
  studentId   String          @map("student_id") @db.Uuid
  category    LicenseCategory
  status      CourseStatus    @default(IN_PROGRESS)
  startedAt   DateTime        @default(now()) @map("started_at")
  completedAt DateTime?       @map("completed_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  school  School @relation(fields: [schoolId], references: [id])
  student User   @relation(fields: [studentId], references: [id])
  exams   Exam[]

  @@index([tenantId])
  @@index([schoolId])
  @@index([studentId])
  @@index([studentId, status])
  @@map("student_courses")
}

model Exam {
  id            String     @id @default(uuid()) @db.Uuid
  tenantId      String     @map("tenant_id") @db.Uuid
  schoolId      String     @map("school_id") @db.Uuid
  courseId      String     @map("course_id") @db.Uuid
  type          ExamType
  scheduledAt   DateTime   @map("scheduled_at")
  location      String?
  result        ExamResult @default(SCHEDULED)
  examinerNotes String?    @map("examiner_notes")
  // Accompanying instructor (typical for practical exams). Optional for theory.
  instructorId  String?    @map("instructor_id") @db.Uuid
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  createdById   String     @map("created_by") @db.Uuid
  updatedById   String     @map("updated_by") @db.Uuid

  course     StudentCourse @relation(fields: [courseId], references: [id])
  instructor User?         @relation("InstructorExams", fields: [instructorId], references: [id])
  createdBy  User          @relation("CreatedByExams", fields: [createdById], references: [id])
  updatedBy  User          @relation("UpdatedByExams", fields: [updatedById], references: [id])

  @@index([tenantId])
  @@index([schoolId])
  @@index([courseId])
  @@index([scheduledAt])
  @@index([instructorId])
  @@map("exams")
}

model PushSubscription {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  endpoint       String
  p256dh         String
  auth           String
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, endpoint])
  @@index([userId])
  @@map("push_subscriptions")
}
