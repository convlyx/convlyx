# Database (Supabase PostgreSQL)
# App runtime → transaction pooler (port 6543). Required for serverless (Vercel
# functions). Transaction mode has no prepared statements; the pg driver uses
# unnamed statements so this is safe — pgbouncer=true is the flag for it.
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migrations + bulk scripts → session pooler (port 5432). Prisma Migrate needs
# DDL/transaction features the transaction pooler can't provide. See prisma.config.ts.
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Platform admin emails (comma-separated)
PLATFORM_ADMIN_EMAILS="your@email.com,partner@email.com"

# Web Push (VAPID keys — generate with: node -e "console.log(require('web-push').generateVAPIDKeys())")
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_CONTACT_EMAIL="convlyx@gmail.com"

# App URL (used for email redirects)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Cron job secret (used for daily reminders endpoint)
CRON_SECRET="your-cron-secret"

# PostHog analytics (optional — leave empty to disable)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# Sentry error monitoring (optional — leave empty to disable)
NEXT_PUBLIC_SENTRY_DSN=""
# Used at build time for source maps upload (optional but recommended)
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Resend — powers the "Pedir demonstração" form on the marketing site
RESEND_API_KEY=""
# Default: "Convlyx <noreply@convlyx.com>". For testing without DNS setup,
# use "onboarding@resend.dev" (Resend's test sender, no DNS required).
RESEND_FROM=""
# Where demo requests are delivered. Defaults to "convlyx@gmail.com".
DEMO_REQUEST_TO=""

# Password used by `npm run db:seed` / `db:seed:demo` for every created
# account. Required when seeding; not used at runtime by the app.
SEED_PASSWORD=""

# Upstash Redis — distributed rate limiting (optional). When BOTH are set, rate
# limits hold across all Vercel instances; otherwise the limiter falls back to
# per-instance in-memory. Provision via Vercel Marketplace → Upstash Redis
# (auto-injects these), or from an Upstash account.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
