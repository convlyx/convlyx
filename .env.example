# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Platform admin emails (comma-separated)
PLATFORM_ADMIN_EMAILS="your@email.com,partner@email.com"

# Web Push (VAPID keys — generate with: node -e "console.log(require('web-push').generateVAPIDKeys())")
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_CONTACT_EMAIL="convlyx@gmail.com"

# App URL (used for email redirects)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Cron job secret (used for daily reminders endpoint)
CRON_SECRET="your-cron-secret"
